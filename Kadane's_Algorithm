class Solution {
    public int maxSubArray(int[] nums) {

        int current = nums[0];
        int maxsum = nums[0];
        for(int i=1;i<nums.length;i++)
        {
            if(current + nums[i] > nums[i])

            {
                current= current + nums[i];
             }
             else
             {
                current=nums[i];
             }

             if(current > maxsum)
             {
                maxsum = current;
             }
        
    }
    return maxsum;
}
}
