class Solution {
    public boolean isSorted(ArrayList<Integer> nums) {
        //your code goes here
            boolean found =false;
            for(int i=0;i<nums.length-1;i++)
            {
                if(nums[i] <= nums[i+1])
                {
                    found=true;
                }
            }
           
            if(found)
            {
                return true;
            }
            else
            {
                return false;
            }
      

    }
}
