class Solution {
    public int stockBuySell(int[] arr, int n) {
        
        int minprice=arr[0];
        int maxprofit=0;

        int profit=0;
        for(int i=1;i<n;i++)
        {
            if( arr[i]  <  minprice)
            {
                minprice=arr[i];
            }

            else
            {
                 profit=arr[i]-minprice;

                if( profit > maxprofit )
                {
                    maxprofit=profit;
                }
               
            }
           
        }
        return maxprofit;
       
    }
}
